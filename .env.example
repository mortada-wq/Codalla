# Codalla environment variables — copy to .env for local dev (never commit).
# For GCP AI Studio: leave most variables unset for sensible defaults.
# On Cloud Run these are set by deploy/gcp/deploy.sh; secrets come from
# Secret Manager.

# ── Database (Optional) ─────────────────────────────────────────────────────
# If unset, the app falls back to an in-memory SQLite database (good for
# development and testing). Set DATABASE_URL to use PostgreSQL in production:
#   postgres://postgres:PASSWORD@localhost:5432/codalla
#   postgres://postgres:PASSWORD@/codalla?host=/cloudsql/PROJECT:REGION:codalla (Cloud Run)
#DATABASE_URL=

# Public URL of the app — used to build the Google OAuth callback
# (${APP_URL}/api/auth/google/callback). For GCP AI Studio, leave unset for auto-detect.
#APP_URL=http://localhost:3000

# ── Auth: Google OAuth ──────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Optional: if unset, set AUTH_DISABLED=true for solo development.
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# Set to "true" to skip Google OAuth entirely (development/testing only).
# Everything is attributed to one implicit "local" user. Never use in production.
# Defaults to "false" unless DATABASE_URL is also unset.
AUTH_DISABLED=true

# Optional access gating — leave unset for open signup.
#ALLOWED_EMAIL_DOMAINS=yourcompany.com
#ALLOWED_EMAILS=a@x.com,b@y.com

# ── Optional ────────────────────────────────────────────────────────────────
# API server port. Defaults to 3000 (GCP AI Studio convention).
# Cloud Run can override this by injecting PORT environment variable.
#PORT=3000

# Server-side default AI provider keys (users can also add their own in
# Settings → API keys).
#OPENROUTER_API_KEY=
#SILICONFLOW_API_KEY=

# Colon-separated roots for "Server folder" projects (shared datasets).
# On Cloud Run, point this at a mounted GCS bucket path.
#CODALLA_DATA_ROOTS=/data
