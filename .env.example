# Codalla environment variables — copy to .env for local dev (never commit).
# On Cloud Run these are set by deploy/gcp/deploy.sh; secrets come from
# Secret Manager.
#
# Codalla has no authentication of its own — every request is attributed to
# one implicit "local" user (see artifacts/api-server/src/middleware/auth.ts).
# There is no login, no session, and no per-user access control. Don't expose
# an instance beyond a trusted network without adding real access control in
# front of it (see deploy/gcp/README.md and deploy/railway/README.md).

# ── Database (required) ─────────────────────────────────────────────────────
# Codalla's schema is Postgres-specific — there is no SQLite/in-memory
# fallback. The server refuses to start without this set.
#   postgres://postgres:PASSWORD@localhost:5432/codalla
#   postgres://postgres:PASSWORD@/codalla?host=/cloudsql/PROJECT:REGION:codalla (Cloud Run)
DATABASE_URL=

# Public URL of the app. Currently informational only.
#APP_URL=http://localhost:3000

# ── Optional ────────────────────────────────────────────────────────────────
# API server port. Defaults to 3000 (GCP AI Studio convention).
# Cloud Run can override this by injecting PORT environment variable.
#PORT=3000

# Server-side default AI provider keys (users can also add their own in
# Settings → API keys).
#OPENROUTER_API_KEY=
#SILICONFLOW_API_KEY=

# Colon-separated roots for "Server folder" projects (shared datasets).
# On Cloud Run, point this at a mounted GCS bucket path.
#CODALLA_DATA_ROOTS=/data
