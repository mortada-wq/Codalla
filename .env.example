# Codalla environment variables — copy to .env for local dev (never commit).
# On Cloud Run these are set by deploy/gcp/deploy.sh; secrets come from
# Secret Manager.

# ── Required ────────────────────────────────────────────────────────────────
# Postgres connection string (lib/db). Local dev example below; on Cloud Run
# the Cloud SQL unix-socket form is used:
#   postgres://postgres:PASSWORD@/codalla?host=/cloudsql/PROJECT:REGION:codalla
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codalla

# Public URL of the app — used to build the Google OAuth callback
# (${APP_URL}/api/auth/google/callback). Dev: the Vite URL.
APP_URL=http://localhost:5173

# ── Auth: Google OAuth only (see PLAN.md) ───────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" to skip sign-in entirely (solo local development only —
# everything is attributed to one implicit "local" user). Never in production.
#AUTH_DISABLED=true

# Optional access gating — leave unset for open signup.
#ALLOWED_EMAIL_DOMAINS=yourcompany.com
#ALLOWED_EMAILS=a@x.com,b@y.com

# ── Optional ────────────────────────────────────────────────────────────────
# API server port. Cloud Run injects PORT itself (8080); dev default is 4000
# to match the Vite proxy.
#PORT=4000

# Server-side default AI provider keys (users can also add their own in
# Settings → API keys).
#OPENROUTER_API_KEY=
#SILICONFLOW_API_KEY=

# Colon-separated roots for "Server folder" projects (shared datasets).
# On Cloud Run, point this at a mounted GCS bucket path.
#CODALLA_DATA_ROOTS=/data
